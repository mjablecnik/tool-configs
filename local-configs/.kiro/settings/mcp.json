{
  "mcpServers": {
    "figma": {
      "url": "https://mcp.figma.com/mcp",
      "disabled": true,
      "autoApprove": [
        "get_design_context",
        "get_screenshot"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ],
      "disabled": true,
      "autoApprove": [
        "browser_navigate",
        "browser_click",
        "browser_take_screenshot"
      ]
    }
  }
}
